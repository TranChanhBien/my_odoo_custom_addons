<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sgt_sale_search_panel_list" model="ir.ui.view">
        <field name="name">sgt.sale.search.panel.field.list</field>
        <field name="model">sgt.sale.search.panel.field</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="field_id"/>
                <field name="icon"/>
                <field name="is_active"/>
            </list>
        </field>
    </record>

    <record id="action_sgt_sale_search_panel_config" model="ir.actions.act_window">
        <field name="name">Cấu hình Search Panel Sales</field>
        <field name="res_model">sgt.sale.search.panel.field</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_sgt_sale_search_panel_config"
              name="Sale Search Panel"
              parent="sale.menu_sale_config"
              action="action_sgt_sale_search_panel_config"
              sequence="100"/>
</odoo>