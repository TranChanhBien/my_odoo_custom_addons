<odoo>
    <record id="view_crm_lead_tree_inherit_custom" model="ir.ui.view">
        <field name="name">crm.lead.tree.inherit.custom</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_case_tree_view_oppor"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="x_lead_flow" optional="show"/>
            </xpath>
        </field>
    </record>

    <record id="view_crm_opportunity_filter_inherit_flow" model="ir.ui.view">
        <field name="name">crm.lead.search.inherit.flow</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.view_crm_case_opportunities_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='assigned_to_me']" position="after">
                <separator/>
                <filter string="Inbound" name="filter_inbound" domain="[('x_lead_flow', '=', 'inbound')]"/>
                <filter string="Outbound" name="filter_outbound" domain="[('x_lead_flow', '=', 'outbound')]"/>
                <separator/>
            </xpath>
            <xpath expr="//filter[@name='stage']" position="after">
                <filter string="Lead Flow" name="groupby_lead_flow" context="{'group_by':'x_lead_flow'}"/>
            </xpath>
        </field>
    </record>
</odoo>