<odoo>
    <record id="view_crm_lead_tree_inherit_tabs" model="ir.ui.view">
        <field name="name">crm.lead.tree.inherit.tabs</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_case_tree_view_oppor"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="x_lead_flow" string="Lead Flow" optional="show"/>
            </xpath>
        </field>
    </record>

    <record id="view_partner_form_inherit_tabs_dynamic" model="ir.ui.view">
        <field name="name">res.partner.form.inherit.tabs.dynamic</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                
                <page string="Opportunities" name="tab_opportunities">
                    <field name="opportunity_ids" 
                        context="{'tree_view_ref': 'crm.crm_case_tree_view_oppor', 'default_partner_id': id}"/>
                </page>

                <page string="Sales" name="tab_sales">
                    <field name="sale_order_ids" 
                           context="{'tree_view_ref': 'sale.view_order_tree', 'default_partner_id': id}"/>
                </page>

                <page string="Invoices" name="tab_invoices">
                    <field name="invoice_ids" 
                           context="{'tree_view_ref': 'account.view_out_invoice_tree', 'default_partner_id': id, 'default_move_type': 'out_invoice'}"/>
                </page>

                <page string="Meetings" name="tab_meetings">
                    <field name="meeting_ids" 
                           context="{'tree_view_ref': 'calendar.view_calendar_event_tree'}"/>
                </page>

            </xpath>
        </field>
    </record>
</odoo>