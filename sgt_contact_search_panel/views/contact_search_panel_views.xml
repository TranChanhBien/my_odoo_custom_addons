<odoo>
    <record id="view_sgt_contact_search_panel_list" model="ir.ui.view">
        <field name="name">sgt.contact.search.panel.field.list</field>
        <field name="model">sgt.contact.search.panel.field</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="field_id"/>
                <field name="icon"/>
                <field name="is_active"/>
            </list>
        </field>
    </record>

    <record id="action_sgt_contact_search_panel_config" model="ir.actions.act_window">
        <field name="name">Cấu hình Search Panel Contacts</field>
        <field name="res_model">sgt.contact.search.panel.field</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_sgt_contact_search_panel_config"
              name="Contact Search Panel"
              parent="contacts.res_partner_menu_config"
              action="action_sgt_contact_search_panel_config"
              sequence="100"/>
</odoo>