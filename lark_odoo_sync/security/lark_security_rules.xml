<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Quy tắc 1: Nhân viên chỉ thấy Task mà mình là người phụ trách -->
        <record id="rule_task_employee_visibility" model="ir.rule">
            <field name="name">RLS: Nhân viên chỉ thấy Task được giao</field>
            <field name="model_id" ref="project.model_project_task"/>
            <!-- Domain Filter: Chỉ lấy các bản ghi có ID của user hiện tại nằm trong trường user_ids -->
            <field name="domain_force">[('user_ids', 'in', user.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- Quy tắc 2: Quản lý thấy toàn bộ Task trong hệ thống -->
        <record id="rule_task_manager_visibility" model="ir.rule">
            <field name="name">RLS: Quản lý dự án thấy toàn bộ Task</field>
            <field name="model_id" ref="project.model_project_task"/>
            <!-- Domain [(1, '=', 1)] là điều kiện luôn đúng, cho phép thấy tất cả -->
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('project.group_project_manager'))]"/>
        </record>
    </data>
</odoo>