<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_task_form2_lark_sync" model="ir.ui.view">
        <field name="name">project.task.form.inherit.lark.sync</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_form2"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Lark Info" name="lark_info" invisible="not lark_task_id">
                    <group>
                        <field name="lark_task_id"/>
                        <field name="lark_url" widget="url" text="Mở Task trên Lark"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>